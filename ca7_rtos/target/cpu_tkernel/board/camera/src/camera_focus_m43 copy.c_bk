double g_dac_pos_coarse_bw_setp = 7.0f;
double g_dac_pos_fine_fw_setp = 5.0f;
double g_dac_pos_fine_bw_setp = 5.0f;

#define D_DAC_POS_INIT				(512)	// Default position

// If your module doesn't have Calibration Data, please tune D_DAC_POS_FW_INIT and D_DAC_POS_BW_INIT by using your module
#define D_DAC_POS_FW_INIT			(0)	// Start position for forward (temporary, need fine tuning)
#define D_DAC_POS_BW_INIT			(1185)	// Start position for backward (temporary, need fine tuning)

#define D_DAC_POS_COARSE_FW_SETP	(15)	// coarse search forward moviing step (temporary, need fine tuning)
#define D_DAC_POS_COARSE_BW_SETP	(15)	// coarse search backward moviing step (temporary, need fine tuning)
#define D_DAC_POS_FINE_FW_SETP		(2)	// fine search forward moviing step (temporary, need fine tuning)
#define D_DAC_POS_FINE_BW_SETP		(2)	// fine search backward moviing step (temporary, need fine tuning)



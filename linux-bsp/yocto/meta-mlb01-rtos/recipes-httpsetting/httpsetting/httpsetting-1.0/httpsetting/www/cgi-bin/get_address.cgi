#!/bin/sh

echo Content-type: application/json; charset=UTF-8
echo 

CAMCOMM="sdk_comm_test"

# --------------------------
# 設定データアドレス取得
# --------------------------

#
echo "IQ_COMMON"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000000 0x00000000
IQ_COMMON=$($CAMCOMM -r 2 0x00040200 0x00000700 0 0)
echo $IQ_COMMON
#
echo "IQ_BIN0"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000000 0x00000001
IQ_BIN0=$($CAMCOMM -r 2 0x00040200 0x00000700 0 1)
echo $IQ_BIN0
#
echo "IQ_BIN1"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000000 0x00000002
IQ_BIN1=$($CAMCOMM -r 2 0x00040200 0x00000700 0 2)
echo $IQ_BIN1
#
echo "AE_COMMON"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000000
AE_COMMON=$($CAMCOMM -r 2 0x00040200 0x00000700 1 0)
echo $AE_COMMON
#
echo "AE_BIN0(AE_S_CAP.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000001
AE_BIN0=$($CAMCOMM -r 2 0x00040200 0x00000700 1 1)
echo $AE_BIN0
#
echo "AE_BIN1(AE_S_MON.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000002
AE_BIN1=$($CAMCOMM -r 2 0x00040200 0x00000700 1 2)
echo $AE_BIN1
#
echo "AE_BIN2(AE_V_HD.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000003
AE_BIN2=$($CAMCOMM -r 2 0x00040200 0x00000700 1 3)
echo $AE_BIN2
#
echo "AE_BIN3(AE_V_FHD.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000004
AE_BIN3=$($CAMCOMM -r 2 0x00040200 0x00000700 1 4)
echo $AE_BIN3
#
echo "AE_BIN4(AE_V_4K.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000005
AE_BIN4=$($CAMCOMM -r 2 0x00040200 0x00000700 1 5)
echo $AE_BIN4
#
echo "AE_BIN5(AE_V_360.BIN)"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000001 0x00000006
AE_BIN5=$($CAMCOMM -r 2 0x00040200 0x00000700 1 6)
echo $AE_BIN5
#
echo "AWB_COMMON"
#
#echo $CAMCOMM 0x00040200 0x00000700 0x00000002 0x00000000
AWB_COMM=$($CAMCOMM -r 2 0x00040200 0x00000700 2 0)
echo $AWB_COMM

#!/bin/sh

echo Content-type: application/json; charset=UTF-8
echo 

CAMCOMM="sdk_comm_test"

echo "Get Image Configuration 0x80010100"
echo " EV Compensation 0x00000100 0x000000XX"
$CAMCOMM -r 1 0x80010100 0x00000100
echo " White Balance 0x00000200 0x0000000X 0xXXXXXXXX 0xXXXXXXXX"
$CAMCOMM -r 3 0x80010100 0x00000200
echo " Color 0x00000300 0x0000000X"
$CAMCOMM -r 1 0x80010100 0x00000300
echo " Sharpness 0x00000400 0x0000000X 0x0000000X"
$CAMCOMM -r 2 0x80010100 0x00000400
echo " ISO 0x00000500 0x0000000X"
$CAMCOMM -r 1 0x80010100 0x00000500
echo " Exposure Time 0x00000600 0x000000XX"
$CAMCOMM -r 1 0x80010100 0x00000600
echo " AE Metering 0x00000700 0x0000000X"
$CAMCOMM -r 1 0x80010100 0x00000700
echo " AE Coverage Speed 0x00000800 0x000000XX"
$CAMCOMM -r 1 0x80010100 0x00000800

echo "Get Preview Configuration 0x80010200"
echo " View Channel 0x00000100 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Size & Frame Rate 0x00000200 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Bitrate 0x00000300 0xXXXXXXXX"
$CAMCOMM -r 1 0x00020100 0x00000100

echo "Get Video Capture Configuration 0x80010400"
echo " Size & Framerate 0x00000100 0x000000XX 0x000000XX"
$CAMCOMM -r 2 0x00020100 0x00000100
echo " Bitrate 0x00000200 0x0000000X 0x0000000X 0xXXXXXXXX 0xXXXXXXXX"
$CAMCOMM -r 4 0x00020100 0x00000100
echo " GOP 0x00000300 0x0000000X 0x0000000X"
$CAMCOMM -r 2 0x00020100 0x00000100
echo " File Path 0x00000400 0xXXXXXXXX 0x0000XXXX"
$CAMCOMM -r 2 0x00020100 0x00000100

echo "Get Image Capture Configuration 0x80010500"
echo " Image Type 0x00000100 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Store Channel 0x00000200 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Capture Size 0x00000300 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Quality 0x00000400 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " File Path 0x00000500 0xXXXXXXXX 0x0000XXXX"
$CAMCOMM -r 2 0x00020100 0x00000100

echo "Get Burst Capture Configuration 0x80010600"
echo " Store Channel 0x00000100 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Capture Size 0x00000200 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Quality 0x00000300 0x0000000X"
$CAMCOMM -r 1 0x00020100 0x00000100
echo " Shooting Condition 0x00000400 0x000000XX 0x0000000X 0x000000XX"
$CAMCOMM -r 3 0x00020100 0x00000100
echo " File Path 0x00000500 0xXXXXXXXX 0x0000XXXX"
$CAMCOMM -r 2 0x00020100 0x00000100

